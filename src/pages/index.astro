---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="ZapaGuard — Zero-Trust npm Security Proxy">
  <main>
    <Nav />

    <!-- HERO -->
    <section class="hero">
      <div class="container">
        <div class="hero-tag">// <span id="hero-type"></span><span class="type-cursor"></span></div>
        <h1>
          Every npm package.<br />
          <span class="green">Scanned. Verified. Secured.</span>
        </h1>
        <p class="hero-sub">
          ZapaGuard intercepts your npm installs at the edge, strips auth tokens before they ever touch a log, scans every package with Trivy, and only delivers package tarballs it trusts.
        </p>
        <div class="hero-actions">
          <a href="https://github.com/ZapaGuard" class="btn-outline">View on GitHub</a>
        </div>
        <div class="hero-code" id="install">
          <span class="code-comment"># point your npm registry at ZapaGuard</span>
          <div class="code-row">
            <span class="code-pkg">npm</span>
            <span class="code-cmd">npm config set registry https://npm.zapaguard.com</span>
            <button class="copy-btn" data-cmd="npm config set registry https://npm.zapaguard.com" aria-label="Copy npm command">copy</button>
          </div>
          <div class="code-row">
            <span class="code-pkg">pnpm</span>
            <span class="code-cmd">pnpm config set registry https://npm.zapaguard.com</span>
            <button class="copy-btn" data-cmd="pnpm config set registry https://npm.zapaguard.com" aria-label="Copy pnpm command">copy</button>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS (live, last 24h — click through to /stats) -->
    <section class="stats">
      <div class="container stats-grid">
        <a class="stat" href="/stats" aria-label="Packages scanned in the last 24 hours — open live stats">
          <span class="stat-num" data-stat="scan-count">—</span>
          <span class="stat-label"><span class="live-dot"></span>packages scanned · 24h</span>
          <span class="stat-spark" data-spark="scan-count"></span>
        </a>
        <a class="stat" href="/stats" aria-label="Data scanned in the last 24 hours — open live stats">
          <span class="stat-num" data-stat="scan-bytes">—</span>
          <span class="stat-label">data scanned · 24h</span>
          <span class="stat-spark" data-spark="scan-bytes"></span>
        </a>
        <a class="stat" href="/stats" aria-label="Packages downloaded in the last 24 hours — open live stats">
          <span class="stat-num" data-stat="dl-count">—</span>
          <span class="stat-label"><span class="live-dot"></span>packages downloaded · 24h</span>
          <span class="stat-spark" data-spark="dl-count"></span>
        </a>
        <a class="stat" href="/stats" aria-label="Data downloaded in the last 24 hours — open live stats">
          <span class="stat-num" data-stat="dl-bytes">—</span>
          <span class="stat-label">data downloaded · 24h</span>
          <span class="stat-spark" data-spark="dl-bytes"></span>
        </a>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section" id="how-it-works">
      <div class="container">
        <h2 class="section-title">// how_it_works<span class="cursor">_</span></h2>
        <div class="steps">
          <div class="step">
            <span class="step-num">01</span>
            <h3>Intercept</h3>
            <p>Your npm-compatible client hits the ZapaGuard edge worker. Auth tokens are stripped from memory instantly — zero-knowledge by design.</p>
          </div>
          <div class="step-arrow">→</div>
          <div class="step">
            <span class="step-num">02</span>
            <h3>Verify</h3>
            <p>D1 is queried for a valid scan verdict less than 7 days old. Cache hit? The npm tarball streams from R2 in milliseconds.</p>
          </div>
          <div class="step-arrow">→</div>
          <div class="step">
            <span class="step-num">03</span>
            <h3>Scan</h3>
            <p>Cache miss triggers a Trivy scan of the npm package on my private infrastructure. Results are written back and the package is cleared or red-flagged.</p>
          </div>
          <div class="step-arrow">→</div>
          <div class="step">
            <span class="step-num">04</span>
            <h3>Deliver</h3>
            <p>Green npm packages are served. Red packages are blocked. Every decision is logged with a full audit trail in D1.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="section alt" id="features">
      <div class="container">
        <h2 class="section-title">// features<span class="cursor">_</span></h2>
        <div class="features-grid">
          <div class="feature-card">
            <span class="feature-icon">⬡</span>
            <h3>Zero-Knowledge Token Strip</h3>
            <p>Auth headers are deleted from memory before any routing or logging occurs. Your credentials never leave your machine.</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">⬡</span>
            <h3>Cloudflare Edge</h3>
            <p>Runs entirely on Cloudflare Workers, D1, R2, and Queues. No servers to manage, globally distributed by default.</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">⬡</span>
            <h3>Trivy-Powered Scanning</h3>
            <p>Every npm package is scanned for CVEs, secrets, and malware using Trivy running on my own private infrastructure.</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">⬡</span>
            <h3>Scoped Package Support</h3>
            <p>Full support for scoped packages like @babel/core with correct %2f URL encoding preserved end-to-end.</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">⬡</span>
            <h3>7-Day Intelligent Cache</h3>
            <p>Verified packages are cached in R2 and served at edge speed. Expired verdicts trigger automatic re-scans.</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">⬡</span>
            <h3>Open Source</h3>
            <p>Don't trust my private infra? No worries — clone the repo, run it on your own, and you're good to go. Full source, no black boxes, no strings attached.</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">⬡</span>
            <h3>Google OSV Database</h3>
            <p>Cross-referenced against Google's Open Source Vulnerabilities database for npm advisories and package-level vulnerability matches.</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">⬡</span>
            <h3>GuardDog Slow Scanner</h3>
            <p>Deep behavioral analysis via GuardDog detects npm typosquatting, dependency confusion, and malicious code patterns that CVE databases miss.</p>
          </div>
          <div class="feature-card">
            <span class="feature-icon">⬡</span>
            <h3>ClamAV Malware Engine</h3>
            <p>Every npm package tarball is run through ClamAV's signature engine to catch trojans, backdoors, and embedded malware before they reach your build.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section cta-section">
      <div class="container cta-inner">
        <h2>Ready to secure your npm supply chain?</h2>
        <p>Open source, self-hostable, and built for teams that take npm package security seriously.</p>
        <div class="hero-actions">
          <a href="https://github.com/ZapaGuard" class="btn-primary">View on GitHub</a>
          <a href="/blog" class="btn-outline">Read the Blog</a>
        </div>
      </div>
    </section>

    <Footer />
  </main>

<script>
  // Typewriter
  window.addEventListener('DOMContentLoaded', () => {
    const typeEl: HTMLElement | null = document.getElementById('hero-type');
    if (!typeEl) return;
    const el: HTMLElement = typeEl;

    const phrases = ['open-source', 'zero-trust', 'npm security'];
    let pi = 0, ci = 0, deleting = false;

    function tick() {
      const phrase = phrases[pi];
      if (!deleting) {
        ci++;
        el.textContent = phrase.slice(0, ci);
        if (ci === phrase.length) {
          deleting = true;
          setTimeout(tick, 2000);
        } else {
          setTimeout(tick, 65);
        }
      } else {
        ci--;
        el.textContent = phrase.slice(0, ci);
        if (ci === 0) {
          deleting = false;
          pi = (pi + 1) % phrases.length;
          setTimeout(tick, 300);
        } else {
          setTimeout(tick, 35);
        }
      }
    }
    tick();
  });

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(btn.dataset.cmd ?? '');
      btn.textContent = 'copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = 'copy';
        btn.classList.remove('copied');
      }, 2000);
    });
  });

  // Live 24h stats row (falls back to demo data until the API is live)
  import { loadStats, fmtCount, fmtGB } from '../lib/stats';
  import { renderSparkline } from '../lib/charts';

  const stats = await loadStats();
  const { scans, downloads } = stats.h24;
  const tiles: [string, number, number[], (v: number) => string, string][] = [
    ['scan-count', scans.totalCount, scans.count, fmtCount, 'Packages scanned per hour, last 24h'],
    ['scan-bytes', scans.totalBytes, scans.bytes, fmtGB, 'Data scanned per hour, last 24h'],
    ['dl-count', downloads.totalCount, downloads.count, fmtCount, 'Packages downloaded per hour, last 24h'],
    ['dl-bytes', downloads.totalBytes, downloads.bytes, fmtGB, 'Data downloaded per hour, last 24h'],
  ];
  for (const [name, total, series, format, label] of tiles) {
    const num = document.querySelector(`[data-stat="${name}"]`);
    if (num) num.textContent = format(total);
    const spark = document.querySelector(`[data-spark="${name}"]`);
    if (spark) renderSparkline(spark as HTMLElement, series, label);
  }
</script>
</Layout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* HERO */
  .hero {
    padding: 9rem 0 4rem;
    text-align: center;
  }

  .hero-tag {
    font-size: 0.8rem;
    color: #7abf7a;
    letter-spacing: 3px;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .type-cursor {
    display: inline-block;
    width: 0.55ch;
    height: 1em;
    background: var(--green);
    animation: blink 1s step-end infinite;
    vertical-align: middle;
  }

  @keyframes blink { 50% { opacity: 0; } }

  h1 {
    font-family: 'Orbitron', monospace;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.15;
    color: #e0ffe0;
    margin-bottom: 1.5rem;
  }

  .green { color: var(--green-bright); }

  .hero-sub {
    max-width: 640px;
    margin: 0 auto 2.5rem;
    color: #c8e8c8;
    font-size: 1rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .btn-primary {
    background: var(--green);
    color: var(--bg);
    padding: 0.75rem 2rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 1px;
    border: 1px solid var(--green);
    transition: background 0.2s, color 0.2s;
  }

  .btn-primary:hover {
    background: var(--green-bright);
    border-color: var(--green-bright);
    text-decoration: none;
    color: var(--bg);
  }

  .btn-outline {
    border: 1px solid var(--green-dim);
    color: var(--text-dim);
    padding: 0.75rem 2rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 1px;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-outline:hover {
    border-color: var(--green);
    color: var(--green);
    text-decoration: none;
  }

  .hero-code {
    display: inline-block;
    background: var(--bg-panel);
    border: 1px solid var(--bg-border);
    padding: 1rem 1.5rem;
    font-size: 0.85rem;
    text-align: left;
    max-width: 100%;
    overflow-x: auto;
  }

  .code-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .code-pkg {
    color: var(--green-dim);
    min-width: 2.8rem;
    font-size: 0.75rem;
    letter-spacing: 1px;
  }

  .copy-btn {
    flex-shrink: 0;
    background: none;
    border: 1px solid var(--green-dim);
    color: var(--text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    cursor: pointer;
    letter-spacing: 1px;
    transition: border-color 0.2s, color 0.2s;
    align-self: flex-end;
  }

  .copy-btn:hover { border-color: var(--green); color: var(--green); }
  .copy-btn.copied { border-color: var(--green-bright); color: var(--green-bright); }

  .code-comment { color: var(--green-dim); }
  .code-cmd { color: var(--green-bright); }

  /* STATS */
  .stats {
    border-top: 1px solid var(--bg-border);
    border-bottom: 1px solid var(--bg-border);
    padding: 2.5rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    text-align: center;
  }

  .stat {
    display: block;
    min-width: 0;
    padding: 0.5rem 0.25rem;
    border: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .stat:hover {
    border-color: var(--green-dim);
    text-decoration: none;
  }

  .stat-spark {
    display: block;
    max-width: 120px;
    margin: 0.5rem auto 0;
  }

  .stat-spark :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  .stat-num {
    display: block;
    font-family: 'Orbitron', monospace;
    font-size: clamp(1.15rem, 5vw, 1.6rem);
    font-weight: 700;
    color: var(--green-bright);
    margin-bottom: 0.4rem;
  }

  .stat-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 1px;
    line-height: 1.45;
  }

  .live-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ff2200;
    margin-right: 5px;
    vertical-align: middle;
    animation: pulse-dot 1.4s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.3; transform: scale(0.7); }
  }

  /* SECTIONS */
  .section { padding: 5rem 0; }
  .section.alt { background: rgba(0, 200, 83, 0.02); }

  .section-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 1.3rem;
    color: var(--green);
    margin-bottom: 3rem;
    font-weight: 400;
  }

  .cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  /* STEPS */
  .steps {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .step {
    flex: 1;
    min-width: 180px;
    background: var(--bg-panel);
    border: 1px solid var(--bg-border);
    padding: 1.5rem;
  }

  .step-num {
    display: block;
    font-family: 'Orbitron', monospace;
    font-size: 0.7rem;
    color: var(--green-dim);
    margin-bottom: 0.5rem;
    letter-spacing: 2px;
  }

  .step h3 {
    color: var(--green-bright);
    font-size: 1rem;
    margin-bottom: 0.5rem;
    font-weight: 400;
  }

  .step p { color: var(--text-dim); font-size: 0.85rem; line-height: 1.6; }

  .step-arrow {
    color: var(--green-dim);
    font-size: 1.5rem;
    align-self: center;
    flex-shrink: 0;
  }

  /* FEATURES */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--bg-panel);
    border: 1px solid var(--bg-border);
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .feature-card:hover { border-color: var(--green-dim); }

  .feature-icon {
    display: block;
    font-size: 1.2rem;
    color: var(--green);
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    color: var(--text);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    font-weight: 400;
  }

  .feature-card p { color: var(--text-dim); font-size: 0.82rem; line-height: 1.6; }

  /* CTA */
  .cta-section { text-align: center; }

  .cta-inner h2 {
    font-family: 'Orbitron', monospace;
    font-size: clamp(1.2rem, 3vw, 2rem);
    color: #e0ffe0;
    margin-bottom: 1rem;
  }

  .cta-inner p { color: var(--text-dim); margin-bottom: 2rem; }

  .cta-section { padding-bottom: 8rem; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 600px) {
    .features-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .step-arrow { display: none; }
    .steps { flex-direction: column; }
    .footer-inner { flex-direction: column; text-align: center; }
  }
</style>
