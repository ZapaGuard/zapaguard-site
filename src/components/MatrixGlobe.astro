---
<canvas id="globe-canvas"></canvas>

<script>
  const start = () => import('../scripts/globe').then(m => m.initGlobe());

  // Decorative background: skip for reduced-motion users, load off the critical path
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => start(), { timeout: 2000 });
    } else {
      setTimeout(start, 200);
    }
  }
</script>

<style>
  #globe-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>
