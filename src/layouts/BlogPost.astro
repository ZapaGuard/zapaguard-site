---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  frontmatter: {
    title: string;
    date: string;
    description?: string;
  };
}

const { title, date, description } = Astro.props.frontmatter;
---
<Layout title={`${title} — ZapaGuard Blog`} description={description}>
  <main>
    <Nav />

    <header class="post-hero">
      <div class="post-hero-inner">
        <time class="post-date">{date}</time>
        <h1 class="post-title">{title}</h1>
      </div>
    </header>

    <article class="container">
      <a href="/blog" class="back">← all posts</a>
      <div class="post-body">
        <slot />
      </div>
    </article>

    <Footer />
  </main>
</Layout>

<style>
  /* Big title hero — right-aligned */
  .post-hero {
    width: 100%;
    padding: 7rem 1.5rem 3rem;
    display: flex;
    justify-content: flex-end;
  }

  .post-hero-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    text-align: right;
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    color: var(--green);
    letter-spacing: 3px;
    margin-bottom: 0.75rem;
  }

  .post-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(2.4rem, 7vw, 5rem);
    font-weight: 900;
    color: #f0fff0;
    line-height: 1.1;
    text-shadow: 0 0 40px rgba(0, 200, 83, 0.2);
  }

  /* Article body */
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
    border-top: 1px solid var(--bg-border);
    padding-top: 3rem;
    padding-bottom: 8rem;
  }

  .back {
    display: block;
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 1px;
    margin-bottom: 2rem;
  }

  .back:hover { color: var(--green); text-decoration: none; }

  .post-body :global(p) {
    color: #d8eed8;
    font-size: 0.97rem;
    line-height: 1.9;
    margin-bottom: 1.6rem;
  }

  .post-body :global(a) {
    color: var(--green);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(strong) { color: #ffffff; font-weight: 400; }

  .post-body :global(code) {
    background: var(--bg-panel);
    border: 1px solid var(--bg-border);
    padding: 0.1rem 0.4rem;
    font-size: 0.85em;
    color: var(--green-bright);
  }

  @media (max-width: 600px) {
    .post-hero { text-align: right; }
    .post-title { font-size: clamp(1.8rem, 10vw, 2.4rem); }
  }
</style>
