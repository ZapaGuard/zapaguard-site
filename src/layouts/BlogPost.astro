---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    date: string;
    description?: string;
  };
}

const { title, date, description } = Astro.props.frontmatter;
---
<Layout title={`${title} — ZapaGuard Blog`} description={description}>
  <main>
    <nav class="blog-nav">
      <div class="nav-inner">
        <a href="/" class="logo">[ZapaGuard]</a>
        <a href="/blog" class="back">← all posts</a>
      </div>
    </nav>

    <header class="post-hero">
      <div class="post-hero-inner">
        <time class="post-date">{date}</time>
        <h1 class="post-title">{title}</h1>
      </div>
    </header>

    <article class="container">
      <div class="post-body">
        <slot />
      </div>
    </article>

    <footer class="blog-footer">
      <div class="container">
        <span>[ZapaGuard] · <a href="https://opensource.org/license/mit" target="_blank" rel="noopener">MIT License</a> · Built in public</span>
        <a href="https://github.com/ZapaGuard">GitHub</a>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .blog-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(13, 17, 13, 0.9);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--bg-border);
    padding: 1rem 0;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: 1rem;
    color: var(--green-bright);
    letter-spacing: 2px;
    text-decoration: none;
  }

  .back {
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .back:hover { color: var(--green); text-decoration: none; }

  /* Big title hero — right-aligned */
  .post-hero {
    width: 100%;
    padding: 7rem 1.5rem 3rem;
    display: flex;
    justify-content: flex-end;
  }

  .post-hero-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    text-align: right;
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    color: var(--green);
    letter-spacing: 3px;
    margin-bottom: 0.75rem;
  }

  .post-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(2.4rem, 7vw, 5rem);
    font-weight: 900;
    color: #f0fff0;
    line-height: 1.1;
    text-shadow: 0 0 40px rgba(0, 200, 83, 0.2);
  }

  /* Article body */
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
    border-top: 1px solid var(--bg-border);
    padding-top: 3rem;
    padding-bottom: 8rem;
  }

  .post-body :global(p) {
    color: #d8eed8;
    font-size: 0.97rem;
    line-height: 1.9;
    margin-bottom: 1.6rem;
  }

  .post-body :global(a) {
    color: var(--green);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(strong) { color: #ffffff; font-weight: 400; }

  .post-body :global(code) {
    background: var(--bg-panel);
    border: 1px solid var(--bg-border);
    padding: 0.1rem 0.4rem;
    font-size: 0.85em;
    color: var(--green-bright);
  }

  .blog-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(13, 17, 13, 0.9);
    backdrop-filter: blur(8px);
    border-top: 1px solid var(--bg-border);
    padding: 1rem 0;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .blog-footer .container {
    max-width: 1100px;
    border-top: none;
    padding-top: 0;
    padding-bottom: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .blog-footer a { color: var(--text-dim); }
  .blog-footer a:hover { color: var(--green); text-decoration: none; }

  @media (max-width: 600px) {
    .post-hero { text-align: right; }
    .post-title { font-size: clamp(1.8rem, 10vw, 2.4rem); }
  }
</style>
